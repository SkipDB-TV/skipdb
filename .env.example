# ---------------------------------------------------------------------------
# SkipDB environment configuration. Copy to `.env` and fill in.
# ---------------------------------------------------------------------------

# Postgres. Matches docker-compose.yml (host port 5433 to avoid local clashes).
DATABASE_URL="postgresql://skipdb:skipdb@localhost:5433/skipdb"
# On Vercel + Supabase: use the transaction-mode pooler URL (port 6543, not 5432).
# Found in Supabase dashboard → Project Settings → Database → Connection Pooling.
# Example: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# DATABASE_URL="postgresql://..."

# Auth.js. Generate a secret with: openssl rand -base64 32
AUTH_SECRET="change-me-with-openssl-rand-base64-32"
# Base URL of the app (used for OAuth callbacks + magic links).
AUTH_URL="http://localhost:3000"

# --- OAuth providers (optional individually; app runs with email-only too) ---
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Email magic links (optional). Standard SMTP. ---
EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
EMAIL_FROM="SkipDB <no-reply@skipdb.tv>"

# --- Metadata providers (optional). Without these, manual IMDb entry still works. ---
# TMDB API read access token (v4) OR api key (v3). Primary provider.
TMDB_API_KEY=""
# TheTVDB v4 API key (optional secondary provider).
TVDB_API_KEY=""

# --- Public URLs ---
# Override to deploy under a different domain (e.g. staging). Defaults are the
# production values baked into the code as fallbacks.
NEXT_PUBLIC_BASE_URL=https://skipdb.tv
NEXT_PUBLIC_API_URL=https://api.skipdb.tv

# --- Bootstrapping ---
# Comma-separated emails auto-promoted to admin on sign-in (first run convenience).
ADMIN_EMAILS=""
